# ── OPC-UA Connection ──────────────────────────────────────────────────────
OPC_SERVER_URL=opc.tcp://CHANGE_ME:4840
OPC_USERNAME=
# Preferir OPC_PASSWORD_FILE (Docker Secret) frente a la variable en claro.
# Si el servidor OPC-UA no requiere usuario/contraseña, dejar ambas en blanco.
OPC_PASSWORD=
OPC_PASSWORD_FILE=/run/secrets/opc_password
OPC_SECURITY_POLICY=Basic256Sha256
OPC_SECURITY_MODE=SignAndEncrypt
OPC_CERTIFICATE_PATH=/certs/client_cert.pem
OPC_PRIVATE_KEY_PATH=/certs/client_key.pem
OPC_PUBLISH_INTERVAL_MS=500
OPC_DATACHANGE_DEADBAND=0.0
OPC_DEADBAND_TYPE=None
OPC_NAMESPACE_INDEX=
OPC_NODE_ID_FILTER=
OPC_TAG_OFFSET=0
OPC_TAG_LIMIT=5000
OPC_SESSION_TIMEOUT_MS=30000

# ── PostgreSQL / TimescaleDB (SERVIDOR REMOTO, no en este compose) ───────────
POSTGRES_HOST=db.internal.example
POSTGRES_PORT=5432
# require      → cifrado en tránsito, sin verificar CA (mínimo aceptable en producción).
# verify-full   → recomendado si la BD tiene CA interna conocida; montar certs/ca.pem en el conector.
POSTGRES_SSL_MODE=require
POSTGRES_DB=scada_db
POSTGRES_USER=connector_user
# Preferir POSTGRES_PASSWORD_FILE (Docker Secret) frente a la variable en claro
POSTGRES_PASSWORD=
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password
POSTGRES_CATALOG_TABLE=opc_tags_catalog
POSTGRES_DATA_TABLE=opc_raw_values
POSTGRES_BATCH_SIZE=1000
POSTGRES_FLUSH_INTERVAL_MS=500
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10
# Poner 0 SOLO si se conecta a través de pgBouncer en modo transaction
POSTGRES_STATEMENT_CACHE_SIZE=100
# true: TimescaleDB (hypertable + compresión). false: PostgreSQL plano (sin hypertable)
POSTGRES_USE_TIMESCALE=true

# ── Spill a disco (buffer persistente ante caídas largas de BD) ──────────────
POSTGRES_SPILL_ENABLED=true
POSTGRES_SPILL_DIR=/var/lib/connector/spill
POSTGRES_SPILL_MAX_MB=1024
POSTGRES_SPILL_SEGMENT_MB=64

# ── Connector Identity / Operación ───────────────────────────────────────────
CONNECTOR_ID=connector-01
LOG_LEVEL=INFO
LOG_FORMAT=json
METRICS_PORT=8000
RECONNECT_MAX_RETRIES=10
RECONNECT_BASE_DELAY_S=2
OPC_QUEUE_MAX_SIZE=500000

# ── Logging ─────────────────────────────────────────────────────────────────────
OPC_LIB_LOG_LEVEL=WARNING
